{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "format": "uri", "description": "User's photo URL" },
        "role": { "type": "string", "enum": ["admin", "client"], "description": "User's role" }
      },
      "required": ["uid", "email"]
    },
    "bookings": {
      "title": "Booking",
      "description": "Training session booking",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User ID of the player" },
        "userEmail": { "type": "string", "format": "email", "description": "User's email" },
        "planName": { "type": "string", "description": "Name of the training plan" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"], "description": "Booking status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the booking was made" }
      },
      "required": ["userId", "userEmail", "planName", "status", "createdAt"]
    },
    "contact_messages": {
      "title": "Contact Message",
      "description": "Message from the contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Sender's name" },
        "email": { "type": "string", "format": "email", "description": "Sender's email" },
        "type": { "type": "string", "description": "Type of training interested in" },
        "message": { "type": "string", "description": "Message content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent" }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profiles"
    },
    "/bookings/{bookingId}": {
      "schema": "bookings",
      "description": "Training session bookings"
    },
    "/contact_messages/{messageId}": {
      "schema": "contact_messages",
      "description": "Contact form submissions"
    }
  }
}
